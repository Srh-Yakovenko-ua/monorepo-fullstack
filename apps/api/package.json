{
  "name": "@app/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --conditions=source --watch --enable-source-maps src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "super-admin": "tsx --conditions=source scripts/super-admin.ts"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "bcryptjs": "catalog:",
    "compression": "catalog:",
    "cookie-parser": "catalog:",
    "date-fns": "catalog:",
    "dotenv": "catalog:",
    "express-rate-limit": "catalog:",
    "helmet": "catalog:",
    "jose": "catalog:",
    "mongoose": "catalog:",
    "nodemailer": "catalog:",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "ua-parser-js": "catalog:",
    "zod": "catalog:",
    "zod-openapi": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "catalog:",
    "@swc-node/register": "catalog:",
    "@swc/core": "catalog:",
    "@types/compression": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/nodemailer": "catalog:",
    "@types/supertest": "catalog:",
    "mongodb-memory-server": "catalog:",
    "pino-pretty": "catalog:",
    "supertest": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
