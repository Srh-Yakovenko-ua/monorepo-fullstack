NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/monorepo_fullstack
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=info

# Super-admins are created via CLI, not env seed:
#   pnpm --filter @app/api super-admin create --login=X --email=Y --password=Z
#   pnpm --filter @app/api super-admin promote --login=X

# Swagger UI at /api/docs. Defaults to "true". Set to "false" to hide in any env.
ENABLE_SWAGGER=true

JWT_SECRET=replace-with-64-char-random-hex-string-generated-via-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=2h

# URL of the FE used to build email confirmation links
FRONTEND_URL=http://localhost:5173

# Email sender + generic SMTP transport
# Works with Mailtrap (sandbox.smtp.mailtrap.io:2525), Resend (smtp.resend.com:587 with user="resend"), any SMTP provider
EMAIL_FROM=no-reply@example.com
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Rate limiting (enable when rate-limit middleware lands)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# Error tracking (enable in production)
# SENTRY_DSN=
