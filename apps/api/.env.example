NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/monorepo_fullstack
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=qwerty

# Swagger UI at /api/docs. Defaults to "true". Set to "false" to hide in any env.
ENABLE_SWAGGER=true

JWT_SECRET=replace-with-64-char-random-hex-string-generated-via-openssl-rand-hex-32
JWT_EXPIRES_IN=1h

# URL of the FE used to build email confirmation links
FRONTEND_URL=http://localhost:5173

# Email provider: "mailtrap" (dev + prod sandbox) or "resend" (real delivery, requires verified domain)
EMAIL_PROVIDER=mailtrap
EMAIL_FROM=no-reply@example.com

# Mailtrap SMTP (used when EMAIL_PROVIDER=mailtrap)
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=
MAILTRAP_SMTP_PASS=

# Resend API key (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Rate limiting (enable when rate-limit middleware lands)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# Error tracking (enable in production)
# SENTRY_DSN=
