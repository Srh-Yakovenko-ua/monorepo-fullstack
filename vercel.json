{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo build --filter=@app/web --filter=@app/api",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
